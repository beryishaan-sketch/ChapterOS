{
  "appId": "com.chapteros.app",
  "appName": "ChapterHQ",
  "webDir": "dist",
  "server": {
    "androidScheme": "https"
  },
  "plugins": {
    "PushNotifications": {
      "presentationOptions": ["badge", "sound", "alert"]
    },
    "SplashScreen": {
      "launchShowDuration": 2000,
      "backgroundColor": "#0F1C3F",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#0F1C3F"
    }
  },
  "ios": {
    "contentInset": "automatic",
    "backgroundColor": "#0F1C3F"
  }
}
